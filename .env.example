# Copy this to .env and fill in your values.
# NEVER commit .env — it contains real credentials.

KALSHI_KEY_ID=your-key-id-here
KALSHI_PRIVATE_KEY_PATH=/data/kalshi_private_key.pem
DB_PATH=/data/kalshi_trades.db

MIN_ENTRY_CENTS=1
MAX_ENTRY_CENTS=2
PROACTIVE_MODE=true
MAX_OPEN_ORDERS=20
MAX_DAILY_SPEND_CENTS=200

# Run: docker exec kalshi-bot python discover.py
# then paste the series tickers it prints here.
BTC_SERIES_TICKERS=

LOOK_AHEAD_SECONDS=1200
MIN_SECONDS_TO_CLOSE=60
SCAN_INTERVAL_SECONDS=30
ORDER_CHECK_INTERVAL_SECONDS=15
